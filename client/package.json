{
	"name": "electrobun-vanilla-vite",
	"version": "1.0.0",
	"type": "module",
	"description": "Electrobun app with vanilla TypeScript and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.14.4"
	},
	"devDependencies": {
		"@fontsource/inter": "^5.2.8",
		"@tailwindcss/vite": "^4.2.1",
		"@types/bun": "latest",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.1.0",
		"material-symbols": "^0.40.2",
		"postcss": "^8.5.8",
		"tailwindcss": "^4.2.1",
		"typescript": "^5.7.2",
		"vite": "^6.0.3"
	}
}
